{
	"schemaVersion": 1,
	"id": "boundbyfate-core",
	"version": "${version}",
	"name": "BoundByFate-Core",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/boundbyfate-core/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "omc.boundbyfate.BoundByFateCore",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "omc.boundbyfate.client.BoundByFateCoreClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"boundbyfate-core.mixins.json",
		{
			"config": "boundbyfate-core.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"satin": ">=1.14.0"
	}
}